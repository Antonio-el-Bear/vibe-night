# vibe-night Clips — Environment Variables
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to git

# ── Instagram (Meta) ─────────────────────────────
# Get from: https://developers.facebook.com/apps
VITE_IG_ACCESS_TOKEN=your_instagram_long_lived_access_token
VITE_IG_USER_ID=your_instagram_user_id

# ── TikTok ───────────────────────────────────────
# Get from: https://developers.tiktok.com
VITE_TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# ── X (Twitter) ──────────────────────────────────
# Get from: https://developer.x.com/en/portal/dashboard
# Note: X OAuth must be handled server-side
VITE_X_API_KEY=your_x_api_key
VITE_X_API_SECRET=your_x_api_secret
VITE_X_ACCESS_TOKEN=your_x_access_token
VITE_X_ACCESS_SECRET=your_x_access_secret

# ── Storage (for video upload before posting) ────
# Choose one: Cloudinary, Supabase, AWS S3, etc.
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
